DEPLOYMENT_ROLE=log_server
JWT_SECRET=change-me-in-production
# 可选：RSA 私钥 PEM（多行用 \n），用于登录密码传输解密；未配置则每次启动自动生成
# RSA_PRIVATE_KEY=
TRUST_PROXY=loopback

# 本地开发留空即可，accessContext 会自动使用当前请求的 origin（如 http://127.0.0.1:30014）
# 部署到 ziye993.cn 后再配置：
# PUBLIC_BASE_URL=https://ziye993.cn:40014
# LOG_API_BASE_URL=https://ziye993.cn:40014

LOG_DB_HOST=ziye993.cn
LOG_DB_PORT=3306
LOG_DB_USER=root
LOG_DB_PASSWORD=
LOG_DB_NAME=pm
